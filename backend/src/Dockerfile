# Optimized Python Dockerfile for demonstration
FROM python:3.11-slim

# Set the working directory directly to /app
WORKDIR /app

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements from the same directory (src/)
COPY requirements.txt .

# Install dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Copy all source files into the container
COPY . .

# Set environment variables
ENV PYTHONUNBUFFERED=1
# No need for PYTHONPATH extra if we're running from the package root

# Expose the API port
EXPOSE 8000

# Start the uvicorn server directly with main:app
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
